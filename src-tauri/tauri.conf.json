{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixiis",
  "version": "0.1.0",
  "identifier": "com.pixiis.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pixiis",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Controller-first launcher with voice",
    "longDescription": "Pixiis is a Windows game launcher that scans Steam, Epic, GOG, Xbox, and EA libraries and offers controller + voice control.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "resources": [
      "../resources/default_config.toml"
    ]
  }
}
